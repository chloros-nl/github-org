# Reference example showing every knob. The real values live in the committed
# terraform.tfvars (no secrets there — auth is via $GITHUB_TOKEN).

github_owner  = "chloros-nl"
billing_email = "you@example.com"

# member privileges / base policy
default_repository_permission           = "read"
members_can_create_public_repositories  = false
members_can_create_private_repositories = true
members_can_fork_private_repositories   = false
web_commit_signoff_required             = true

# security defaults for NEW repos (free for public repos)
dependabot_alerts_enabled_for_new_repositories              = true
dependabot_security_updates_enabled_for_new_repositories    = true
dependency_graph_enabled_for_new_repositories               = true
secret_scanning_enabled_for_new_repositories                = true
secret_scanning_push_protection_enabled_for_new_repositories = true

# org-wide Actions policy
actions_allowed_actions      = "selected" # all | local_only | selected
actions_enabled_repositories = "all"      # all | none
actions_sha_pinning_required = true
actions_allowed_actions_config = {
  github_owned_allowed = true
  verified_allowed     = true
  patterns_allowed     = ["my-org/*"]
}

# Branch protection. The SAME organization_rulesets definitions drive both:
#   paid_plan_features_enabled = true  -> one org-wide ruleset (needs Team; the
#                                         resource is commented out in rulesets.tf
#                                         and must be uncommented to enforce)
#   paid_plan_features_enabled = false -> the same rules applied per-repo (free,
#                                         PUBLIC repos only; private repos can't
#                                         have rulesets on Free)
paid_plan_features_enabled = false

# Blunt global opt-out across all free rulesets; prefer per-ruleset scoping.
fallback_excluded_repos = []

organization_rulesets = {
  # Most repos: full branch protection. Exclude the config repo (CI direct-push).
  "default-branch-protection" = {
    enforcement                     = "active"
    include_refs                    = ["~DEFAULT_BRANCH"]
    include_repos                   = ["~ALL"]       # paid path only
    exclude_repos                   = ["github-org"] # honored by both paths
    require_pull_request            = true
    required_approving_reviews      = 1
    require_conversation_resolution = true
    required_status_checks          = ["build", "test"]
    block_force_push                = true
    block_deletion                  = true
    bypass_org_admins               = true
  }
  # The config repo: lock history without requiring PRs (so CI can still push).
  "config-repo-no-rewrite" = {
    enforcement          = "active"
    include_refs         = ["~DEFAULT_BRANCH"]
    include_repos        = ["github-org"]
    require_pull_request = false
    block_force_push     = true
    block_deletion       = true
    bypass_org_admins    = false
  }
}

# Org self-hosted runner groups (PAID: requires GitHub Team; gated by
# paid_plan_features_enabled). Manages the access-scoping GROUP only — install
# the runner agent on the host separately with `./config.sh --runner-group
# "<name>"`. On Free, omit this and use the built-in "Default" group.
actions_runner_groups = {
  "self-hosted-linux" = {
    visibility            = "selected" # all | selected | private
    selected_repositories = ["topos"]  # repo NAMES; only when visibility = "selected"

    # Leave false: a public-repo PR could run untrusted code on the runner host.
    allows_public_repositories = false

    # Optionally restrict which workflows may run on this group.
    restricted_to_workflows = true
    selected_workflows      = ["chloros-nl/topos/.github/workflows/ci.yml@refs/heads/main"]
  }
}

teams = {
  maintainers = {
    description = "Org maintainers"
    privacy     = "closed"
    members = {
      yhu02 = "maintainer"
    }
  }
}
